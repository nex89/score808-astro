---
// src/pages/nonton.astro
---
<!doctype html>
<html>
<head>
    <title>Redirecting...</title>
    <style>
        body { background: #000; color: #00ff88; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: sans-serif; }
    </style>
</head>
<body>
    <div id="status">Menghubungkan ke Server HD...</div>

    <script is:inline>
        // Kita pecah link-nya biar nggak kebaca bot/script sederhana
        const part1 = "https://";
        const part2 = "cukurukuk";
        const part3 = ".co";
        const finalDest = part1 + part2 + part3;

        // Tunggu 1 detik biar user "terhitung" mampir di web kamu
        setTimeout(() => {
            document.getElementById('status').innerText = "Sinyal Ditemukan! Mengalihkan...";
            window.location.href = finalDest;
        }, 1200);
    </script>
    <script is:inline>
        // Block Klik Kanan
        document.addEventListener('contextmenu', event => event.preventDefault());
      
        // Block F12 dan Shortcut Inspect/View Source
        document.onkeydown = function(e) {
          if (e.keyCode == 123 || 
              (e.ctrlKey && e.shiftKey && (e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'J'.charCodeAt(0))) || 
              (e.ctrlKey && e.keyCode == 'U'.charCodeAt(0))) {
            return false;
          }
        };
      </script>
</body>
</html>